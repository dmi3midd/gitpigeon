# Server
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# Database (override in docker-compose, keep default for local dev)
DB_PATH=./sql.db

# API authentication
API_KEY=your-secret-api-key-here

# GitHub (optional, increases rate limit from 60 to 5000 req/h)
GITHUB_TOKEN=

# Release scanner interval in minutes
SCAN_INTERVAL=15

# SMTP configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
